{
  "name": "h2h-iracing",
  "version": "1.0.0",
  "description": "head2head overlay for iRacing",
  "license": "ISC",
  "author": "",
  "type": "module",
  "main": "index.js",
  "scripts": {
    "server:dev:mock": "DATA_MODE=mock node --env-file=.env --watch src/server.ts",
    "cli:dev:mock": "DATA_MODE=mock node --env-file=.env src/cli.ts",
    "server:start": "node --env-file=.env src/server.ts",
    "cli:start": "node --env-file=.env src/cli.ts",
    "test": "vitest run --coverage",
    "lint": "biome check --write .",
    "build": "tsc"
  },
  "imports": {
    "#service/*": "./src/service/*",
    "#repository/*": "./src/repository/*",
    "#schema/*": "./src/schema/*",
    "#error/*": "./src/error/*",
    "#config": "./src/config.ts",
    "#router/*": "./src/router/*",
    "#utils/*": "./src/utils/*"
  },
  "dependencies": {
    "@emiliosp/node-iracing-sdk": "1.0.9",
    "@hono/node-server": "1.19.10",
    "@hono/node-ws": "1.3.0",
    "hono": "4.12.4",
    "zod": "4.3.6"
  },
  "devDependencies": {
    "@biomejs/biome": "2.4.5",
    "@types/node": "24.11.0",
    "@vitest/coverage-v8": "^4.0.18",
    "tsx": "4.21.0",
    "typescript": "5.9.3",
    "vitest": "4.0.18"
  }
}
